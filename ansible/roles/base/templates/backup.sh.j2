#!/bin/bash
set -e

export RESTIC_REPOSITORY="{{ restic_repository }}"
export RESTIC_PASSWORD="{{ restic_pass }}"
{% for key, value in restic_env.items() %}
export {{ key }}="{{ value }}"
{% endfor %}

{% if backup_usb is defined %}
# Abort early if the backup drive isn't mounted
if ! mountpoint -q "{{ backup_usb.path }}"; then
    echo "ERROR: backup drive is not mounted at {{ backup_usb.path }}!"
    exit 1
fi

{% endif %}
# Initialise the repo if it doesn't exist yet (prevents a failing first backup)
if ! restic snapshots &>/dev/null; then
    echo "Restic repo not initialised yet. Creating it..."
    restic init
fi

# Make sure the stack comes back up even if the backup fails halfway
restart_stack() {
    echo "Restarting the stack..."
    docker compose --project-directory "{{ appdata_dir }}" start || true
}
trap restart_stack EXIT

echo "Stopping the stack for a consistent backup..."
docker compose --project-directory "{{ appdata_dir }}" stop

echo "Starting Restic backup..."
restic backup {{ appdata_dir }} \
  --exclude="{{ appdata_dir }}/jellyfin/metadata" \
  --exclude="{{ appdata_dir }}/jellyfin/transcodes"

echo "Pruning old backups..."
restic forget --keep-daily 7 --keep-weekly 4 --keep-monthly 6 --prune
{% if backup_healthcheck_url %}

# Report success — if this ping stays away, the monitoring service alerts you
curl -fsS -m 10 --retry 3 "{{ backup_healthcheck_url }}" > /dev/null || true
{% endif %}
