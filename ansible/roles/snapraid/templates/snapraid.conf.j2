# SnapRAID configuration — generated by Ansible, do not edit by hand
{% for d in snapraid_parity_disks %}
{% if loop.first %}
parity {{ d.path }}/snapraid.parity
{% else %}
{{ loop.index }}-parity {{ d.path }}/snapraid.parity
{% endif %}
{% endfor %}

content /var/snapraid/snapraid.content
{% for d in data_disks %}
content {{ d.path }}/snapraid.content
{% endfor %}

{% for d in data_disks %}
data d{{ loop.index }} {{ d.path }}
{% endfor %}

# Skip incomplete downloads and filesystem internals
exclude /lost+found/
exclude *.!qB
exclude *.unrecoverable
